# Copiar a .env y ajustar para el entorno (no commitear .env real).
# Los secrets sin default son OBLIGATORIOS (fail-closed): el stack no arranca sin ellos.

POSTGRES_DB=saas
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me_strong_pg_password
APP_API_PASSWORD=change_me_strong_app_api_password

RABBITMQ_USER=guest
RABBITMQ_PASSWORD=change_me_rabbitmq_password

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password

# OpenSearch
OPENSEARCH_INITIAL_ADMIN_PASSWORD=change_me_opensearch_strong_password

# Traefik dashboard (dev only; in prod use OAuth/SSO)
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD=change_me_traefik_dashboard_password
