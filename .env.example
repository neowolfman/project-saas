# ──────────────────────────────────────────────────────────
#  Variables de entorno para la aplicación SaaS PM+FinOps
#  Copiar a .env y ajustar según entorno.
#  Las variables de infraestructura (contraseñas) van en
#  infra/docker/.env — ver infra/docker/.env.example.
# ──────────────────────────────────────────────────────────

# ── Entorno ─────────────────────────────────────────────
NODE_ENV=development
PYTHON_ENV=development
LOG_LEVEL=DEBUG

# ── Base de datos (para la aplicación, usa app_api) ─────
DATABASE_URL=postgresql+asyncpg://app_api:app_api_password@localhost:5432/saas
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_RECYCLE=3600

# ── Redis (cache + rate limiting) ───────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# ── RabbitMQ (broker de mensajes) ───────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ── MinIO (object storage) ─────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_AUDIT=audit-ledger-archive
MINIO_SECURE=false

# ── OpenSearch (búsqueda + analítica) ───────────────────
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin

# ── JWT / Autenticación ────────────────────────────────
JWT_SECRET_KEY=change_me_jwt_secret_at_least_32_chars
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Frontend ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_LANDING_URL=http://localhost:3001

# ── Observabilidad ─────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=saas-pm-finops
