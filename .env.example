# ──────────────────────────────────────────────────────────
#  Variables de entorno para la aplicación SaaS PM+FinOps
#  Copiar a .env y ajustar según entorno.
#  Las variables de infraestructura (contraseñas) van en
#  infra/docker/.env — ver infra/docker/.env.example.
#
#  IMPORTANTE: Los hostnames usan los nombres de servicio de
#  Docker Compose (comunicación inter-contenedor por red interna).
#  Para desarrollo fuera de Docker, reemplazar con "localhost".
# ──────────────────────────────────────────────────────────

# ── Entorno ─────────────────────────────────────────────
NODE_ENV=development
PYTHON_ENV=development
LOG_LEVEL=INFO

# ── Base de datos (para la aplicación, usa app_api) ─────
# Host: nombre del servicio Docker "postgres" (data-net)
DATABASE_URL=postgresql+asyncpg://app_api:app_api_password@postgres:5432/saas
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_RECYCLE=3600

# ── Redis (cache + rate limiting) ───────────────────────
# Host: nombre del servicio Docker "redis" (data-net)
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50

# ── RabbitMQ (broker de mensajes) ───────────────────────
# Host: nombre del servicio Docker "rabbitmq" (data-net)
RABBITMQ_URL=amqp://guest:change_me_rabbitmq_password@rabbitmq:5672/

# ── MinIO (object storage) ─────────────────────────────
# Host: nombre del servicio Docker "minio" (data-net)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio_password
MINIO_BUCKET_AUDIT=audit-ledger-archive
MINIO_SECURE=false

# ── OpenSearch (búsqueda + analítica) ───────────────────
# Host: nombre del servicio Docker "opensearch" (data-net)
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=change_me_opensearch_strong_password

# ── JWT / Autenticación ────────────────────────────────
JWT_SECRET=change_me_jwt_secret_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Frontend ───────────────────────────────────────────
# Las URLs públicas del frontend siguen apuntando a los dominios Traefik
# (accedidos desde el browser, no desde dentro de Docker)
NEXT_PUBLIC_API_URL=http://api.saas.local
NEXT_PUBLIC_APP_URL=http://app.saas.local
NEXT_PUBLIC_LANDING_URL=http://saas.local

# ── Observabilidad ─────────────────────────────────────
# Host: nombre del servicio Docker "tempo" (data-net) — receptor OTLP gRPC
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
OTEL_SERVICE_NAME=saas-pm-finops
