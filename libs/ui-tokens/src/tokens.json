{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "bg": { "base": "#0a0e14", "raised": "#11161f", "sunken": "#070a0f", "overlay": "#161c28" },
    "surface": { "DEFAULT": "#11161f", "hover": "#161d2a", "active": "#1b2333" },
    "border": { "subtle": "#1f2735", "DEFAULT": "#2a3344", "strong": "#3a4658" },
    "fg": { "primary": "#e6edf6", "secondary": "#9aa7bd", "muted": "#5e6b82" },
    "brand": { "500": "#2dd4bf", "600": "#14b8a6", "400": "#5eead4", "contrast": "#04110f" },
    "accent": { "lime": "#a3e635", "amber": "#fbbf24", "violet": "#a78bfa" },
    "semantic": { "success": "#34d399", "warning": "#fbbf24", "danger": "#f87171", "info": "#60a5fa" },
    "data": { "c1": "#2dd4bf", "c2": "#a3e635", "c3": "#60a5fa", "c4": "#a78bfa", "c5": "#fbbf24", "c6": "#f87171" }
  },
  "font": {
    "sans": "Geist, ui-sans-serif, system-ui, sans-serif",
    "mono": "Geist Mono, ui-monospace, 'JetBrains Mono', monospace",
    "scale": { "xs": "0.75rem", "sm": "0.875rem", "base": "1rem", "lg": "1.125rem", "xl": "1.375rem", "2xl": "1.75rem", "3xl": "2.25rem", "4xl": "3rem" }
  },
  "space": { "0": "0", "1": "0.25rem", "2": "0.5rem", "3": "0.75rem", "4": "1rem", "5": "1.5rem", "6": "2rem", "7": "3rem", "8": "4rem" },
  "radius": { "sm": "0.375rem", "DEFAULT": "0.5rem", "lg": "0.75rem", "xl": "1rem", "full": "9999px" },
  "shadow": { "sm": "0 1px 2px rgba(0,0,0,0.4)", "DEFAULT": "0 4px 12px rgba(0,0,0,0.45)", "glow": "0 0 0 1px rgba(45,212,191,0.35), 0 0 24px rgba(45,212,191,0.15)" },
  "z": { "base": "0", "raised": "10", "sticky": "20", "drawer": "40", "modal": "100", "toast": "1000" },
  "motion": { "fast": "150ms", "base": "200ms", "slow": "300ms", "ease": "cubic-bezier(0.22, 1, 0.36, 1)" },
  "breakpoint": { "sm": "640px", "md": "768px", "lg": "1024px", "xl": "1280px", "2xl": "1440px" }
}
