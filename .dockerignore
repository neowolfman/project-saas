# =============================================================================
# Root .dockerignore — se aplica cuando el build context es el repo root.
# Se aplica a TODOS los Dockerfiles. Cada Dockerfile copia solo lo que necesita.
# =============================================================================

# ---------- OS ----------
.DS_Store
Thumbs.db

# ---------- VCS ----------
.git
.gitignore

# ---------- Agent tooling ----------
.agents/

# ---------- Editors ----------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------- Node / Next.js (build artifacts) ----------
node_modules/
.next/
out/
build/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
.turbo/

# ---------- Nx ----------
.nx/cache
.nx/workspace-data

# ---------- Python (build artifacts) ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
.eggs/
dist/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.tox/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# ---------- Env / secrets ----------
.env
.env.*
**/.env
**/.env.*
!.env.example
*.pem
*.key
secrets/

# ---------- Logs ----------
logs/
*.log

# ---------- Docs / tools (no se necesitan en imágenes Docker) ----------
docs/
tools/
README.md
PROJECT_STATUS.md
Makefile
skills-lock.json
