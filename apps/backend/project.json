{
  "name": "backend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/backend/src",
  "projectType": "application",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "python -m ruff check apps/backend/src" }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "python -m mypy apps/backend/src" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "cd apps/backend && python -m pytest" }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": { "command": "uvicorn apps.backend.src.main:app --reload --port 8000" }
    },
    "migrate": {
      "executor": "nx:run-commands",
      "options": { "command": "cd apps/backend && alembic -c migrations/alembic.ini upgrade head" }
    }
  },
  "tags": ["type:app", "scope:backend", "type:app-backend"]
}
